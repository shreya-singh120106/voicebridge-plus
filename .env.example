# ✅ Backend API
NEXT_PUBLIC_API_URL=http://localhost:5000

# ✅ Vapi (Frontend ONLY needs these)
NEXT_PUBLIC_VAPI_KEY=your_vapi_public_key_here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# ❌ DO NOT expose OpenAI key in frontend (remove this)
# NEXT_PUBLIC_OPENAI_API_KEY=...

# ❌ Qdrant should NOT be in frontend env
# NEXT_PUBLIC_QDRANT_URL=...
# NEXT_PUBLIC_QDRANT_API_KEY=...